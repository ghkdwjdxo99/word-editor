<Window x:Class="SimpleWordEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleWordEditor"
        mc:Ignorable="d"
        Title="제목 없음 - 간단 워드 편집기" Height="720" Width="1000" MinHeight="450" MinWidth="650"
        Closing="Window_Closing">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom"><TextBlock x:Name="StatusText" /></StatusBar>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_파일">
                <MenuItem Header="새 문서" InputGestureText="Ctrl+N" Click="New_Click"/><MenuItem Header="열기" InputGestureText="Ctrl+O" Click="Open_Click"/>
                <Separator/><MenuItem Header="저장" InputGestureText="Ctrl+S" Click="Save_Click"/><MenuItem Header="다른 이름으로 저장" InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click"/>
                <Separator/><MenuItem Header="종료" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_편집">
                <MenuItem Header="실행 취소" Command="ApplicationCommands.Undo"/><MenuItem Header="다시 실행" Command="ApplicationCommands.Redo"/><Separator/>
                <MenuItem Header="잘라내기" Command="ApplicationCommands.Cut"/><MenuItem Header="복사" Command="ApplicationCommands.Copy"/><MenuItem Header="붙여넣기" Command="ApplicationCommands.Paste"/><MenuItem Header="전체 선택" Command="ApplicationCommands.SelectAll"/>
                <Separator/><MenuItem Header="찾기" InputGestureText="Ctrl+F" Click="Find_Click"/>
            </MenuItem>
        </Menu>
        <ToolBarTray DockPanel.Dock="Top"><ToolBar>
            <ToggleButton x:Name="BoldButton" IsThreeState="True" Content="굵게" FontWeight="Bold" Click="Bold_Click" ToolTip="굵게 (Ctrl+B)"/>
            <ToggleButton x:Name="ItalicButton" IsThreeState="True" Content="기울임" FontStyle="Italic" Click="Italic_Click" ToolTip="기울임 (Ctrl+I)"/>
            <ToggleButton x:Name="UnderlineButton" IsThreeState="True" Content="밑줄" Click="Underline_Click" ToolTip="밑줄 (Ctrl+U)"/>
            <Separator/><ComboBox x:Name="FontSizeBox" Width="70" IsEditable="True" SelectionChanged="FontSize_Changed" KeyDown="FontSize_KeyDown">
                <ComboBoxItem Content="8"/><ComboBoxItem Content="9"/><ComboBoxItem Content="10"/><ComboBoxItem Content="11" IsSelected="True"/><ComboBoxItem Content="12"/><ComboBoxItem Content="14"/><ComboBoxItem Content="16"/><ComboBoxItem Content="18"/><ComboBoxItem Content="24"/><ComboBoxItem Content="36"/><ComboBoxItem Content="48"/><ComboBoxItem Content="72"/>
            </ComboBox>
            <Separator/><ToggleButton x:Name="LeftButton" IsThreeState="True" Content="왼쪽" Click="Left_Click"/><ToggleButton x:Name="CenterButton" IsThreeState="True" Content="가운데" Click="Center_Click"/><ToggleButton x:Name="RightButton" IsThreeState="True" Content="오른쪽" Click="Right_Click"/>
        </ToolBar></ToolBarTray>
        <Border x:Name="FindPanel" DockPanel.Dock="Top" Visibility="Collapsed" BorderBrush="#B8B8B8" BorderThickness="0,0,0,1" Background="#F4F4F4" Padding="8">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right" Content="닫기" Click="CloseFind_Click" Margin="6,0,0,0" Padding="8,3"/>
                <TextBlock DockPanel.Dock="Left" Text="찾기" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="FindTextBox" Width="240" TextChanged="FindText_Changed" KeyDown="FindText_KeyDown"/>
                <CheckBox x:Name="MatchCaseCheckBox" Content="대소문자 구분" Margin="10,0" VerticalAlignment="Center" Checked="FindOptions_Changed" Unchecked="FindOptions_Changed"/>
                <Button Content="이전" Click="FindPrevious_Click" Padding="8,3"/><Button Content="다음" Click="FindNext_Click" Margin="4,0,0,0" Padding="8,3"/>
                <TextBlock x:Name="FindStatusText" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#555"/>
            </DockPanel>
        </Border>
        <RichTextBox x:Name="Editor" AcceptsTab="True" VerticalScrollBarVisibility="Auto" TextChanged="Editor_TextChanged" SelectionChanged="Editor_SelectionChanged" Padding="20" FontFamily="맑은 고딕" FontSize="14.6667"/>
    </DockPanel>
</Window>
